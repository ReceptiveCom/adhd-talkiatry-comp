<!-- Zendesk (deferred to first interaction or 4s to keep it off the critical path) -->
<script is:inline>
  (function () {
    var loaded = false;
    function loadZendesk() {
      if (loaded) return;
      loaded = true;
      var s = document.createElement("script");
      s.id = "ze-snippet";
      s.src = "https://static.zdassets.com/ekr/snippet.js?key=90f4be18-af38-4f27-9de9-abbec8d97227";
      document.body.appendChild(s);
    }
    setTimeout(loadZendesk, 4000);
    ["mousemove", "scroll", "keydown", "touchstart"].forEach(function (evt) {
      window.addEventListener(evt, loadZendesk, { once: true, passive: true });
    });
  })();
</script>

