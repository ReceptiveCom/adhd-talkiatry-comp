---
const MNT = "/c/adhd-advisor-vs-talkiatry";
const IMG = import.meta.env.DEV ? "/images" : `${MNT}/images`;
const CANON = "https://www.adhdadvisor.org/c/adhd-advisor-vs-talkiatry";
const OG = "https://cdn.prod.website-files.com/63fce4b70b584bed898260ea/687ab4c58df5f8ce2639628d_Frame%202095587865.png";
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ADHD Advisor vs. Talkiatry (2026): Cost, Wait Times & Which Fits You | ADHDAdvisor.org</title>
<meta name="description" content="Comparing ADHD Advisor and Talkiatry for online ADHD care? The honest side-by-side: insurance vs. flat pricing, wait times, medication options, and who each service is genuinely right for.">
<meta name="robots" content="noindex, nofollow">
<link rel="canonical" href={CANON}>

<!-- Open Graph / Twitter -->
<meta property="og:type" content="website">
<meta property="og:title" content="ADHD Advisor vs. Talkiatry (2026): Cost, Wait Times & Which Fits You">
<meta property="og:description" content="The honest side-by-side: insurance vs. flat pricing, wait times, medication options, and who each service is genuinely right for.">
<meta property="og:image" content={OG}>
<meta property="og:url" content={CANON}>
<meta name="twitter:card" content="summary_large_image">

<!-- Favicon (Webflow Cloud pages don't inherit the main site favicon) -->
<link rel="shortcut icon" href="https://cdn.prod.website-files.com/63fce4b70b584bed898260ea/66ab656a04d254117645f9cb_favicon-32.png" type="image/x-icon">
<link rel="apple-touch-icon" href="https://cdn.prod.website-files.com/63fce4b70b584bed898260ea/66ab65715f3562a5ef010486_favicon-256.png">
<link rel="preconnect" href="https://cdn.prod.website-files.com">
<link rel="preconnect" href="https://www.googletagmanager.com">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;600;700;800&family=Inter:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">

<!-- Google Tag Manager (ADHD Advisor — hostname-gated so localhost/staging don't pollute analytics) -->
<script is:inline>
  (function () {
    if (window.location.hostname.indexOf("adhdadvisor.org") < 0) return;
    (function (w, d, s, l, i) {
      w[l] = w[l] || [];
      w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
      var f = d.getElementsByTagName(s)[0],
        j = d.createElement(s),
        dl = l != "dataLayer" ? "&l=" + l : "";
      j.async = true;
      j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
      f.parentNode.insertBefore(j, f);
    })(window, document, "script", "dataLayer", "GTM-KQB4K9X");
  })();
</script>

<!-- Convert.com (A/B test eligibility — loaded sync by design to prevent flicker) -->
<script is:inline type="text/javascript" src="https://cdn-4.convertexperiments.com/v1/js/10041372-10042642.js"></script>

<style is:global>
  :root {
    --navy: #03275C;
    --navy-deep: #021A40;
    --ink: #10203C;
    --ink-2: #44506B;
    --ink-3: #6E7890;
    --teal: #03818E;
    --teal-deep: #026672;
    --cloud: #EFF7FA;
    --paper: #FFFFFF;
    --line: rgba(3, 39, 92, 0.14);
    --line-soft: rgba(3, 39, 92, 0.08);
    --green-tp: #00B67A;
    --sans: 'Plus Jakarta Sans', sans-serif;
    --text: 'Inter', sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    font-family: var(--text);
    font-size: 16.5px;
    line-height: 1.65;
    color: var(--ink);
    background: var(--paper);
    -webkit-font-smoothing: antialiased;
  }

  ::selection { background: rgba(4,160,175,0.22); }

  h1, h2, h3 { font-family: var(--sans); color: var(--navy); text-wrap: pretty; }
  h1 { font-size: clamp(36px, 5.2vw, 58px); font-weight: 800; line-height: 1.06; letter-spacing: -0.033em; }
  h2 { font-size: clamp(28px, 3.6vw, 40px); font-weight: 800; line-height: 1.1; letter-spacing: -0.025em; }
  h3 { font-size: 18px; font-weight: 700; letter-spacing: -0.01em; }
  p  { color: var(--ink-2); text-wrap: pretty; }

  /* The accent — colour, not typeface */
  .em { color: var(--teal); }

  .wrap { max-width: 1140px; margin: 0 auto; padding: 0 28px; }

  /* ── Document index running heads ── */
  .sec { padding: 88px 0 0; }
  .sec-head {
    display: flex;
    align-items: baseline;
    gap: 16px;
    border-top: 1px solid var(--line);
    padding-top: 14px;
    margin-bottom: 40px;
  }
  .sec-num {
    font-family: var(--sans);
    font-weight: 700;
    font-size: 13px;
    color: var(--teal);
    min-width: 30px;
    letter-spacing: 0.04em;
  }
  .sec-name {
    font-family: var(--sans);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--navy);
  }
  .sec-aside {
    margin-left: auto;
    font-size: 13px;
    color: var(--ink-3);
  }
  .sec h2 { max-width: 640px; margin-bottom: 18px; }
  .sec-intro { max-width: 560px; font-size: 17px; margin-bottom: 44px; }

  /* ── Links & buttons ── */
  .tlink {
    color: var(--teal-deep);
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid rgba(2,102,114,0.35);
    padding-bottom: 1px;
    transition: border-color 0.15s;
  }
  .tlink:hover { border-color: var(--teal-deep); }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: var(--teal);
    color: #fff;
    font-family: var(--sans);
    font-size: 16.5px;
    font-weight: 700;
    letter-spacing: -0.005em;
    padding: 17px 30px;
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.18s;
    white-space: nowrap;
  }
  .btn:hover { background: var(--teal-deep); }
  .btn .a { display: inline-block; transition: transform 0.18s; }
  .btn:hover .a { transform: translateX(4px); }

  /* ── Forbes press bar (canonical) ── */
  .press-bar { background: #000; padding: 12px 24px; }
  .press-bar-inner { display: flex; align-items: center; justify-content: center; }
  .press-bar-link { display: inline-flex; align-items: center; gap: 18px; text-decoration: none; line-height: 1; }
  .press-logo { height: 22px; width: auto; display: block; }
  .press-text { font-family: var(--text); font-size: 14.5px; font-weight: 600; color: #fff; line-height: 1; }
  .press-badge { font-family: var(--sans); font-size: 13.5px; font-weight: 700; color: #fff; letter-spacing: 0.08em; line-height: 1; display: inline-flex; align-items: center; gap: 6px; }
  @media (max-width: 900px) { .press-text { display: none; } .press-bar-link { gap: 14px; } }
  @media (max-width: 600px) { .press-logo { height: 18px; } .press-badge { font-size: 12px; } .press-bar { padding: 10px 16px; } }

  /* ── Site header ── */
  .site-header { background: #fff; border-bottom: 1px solid var(--line-soft); }
  .site-header-inner {
    max-width: 1140px; margin: 0 auto; padding: 0 28px;
    display: flex; align-items: center; gap: 36px;
    height: 72px;
  }
  .site-header-logo { display: flex; align-items: center; }
  .site-header-logo img { width: 190px; height: auto; display: block; }
  .site-nav { display: flex; align-items: center; gap: 28px; margin-left: auto; }
  .site-nav a {
    font-family: var(--text); font-size: 14.5px; font-weight: 500;
    color: var(--ink); text-decoration: none;
  }
  .site-nav a:hover { color: var(--teal-deep); }
  .site-header .btn { font-size: 14.5px; padding: 12px 22px; }
  @media (max-width: 900px) {
    .site-nav { display: none; }
    .site-header-inner { height: 64px; justify-content: space-between; gap: 16px; }
    .site-header-logo img { width: 160px; }
  }

  /* ── HERO ── */
  .hero { background: var(--navy); color: #fff; }
  .hero-main {
    padding: 40px 0 52px;
    display: grid;
    grid-template-columns: 1fr 350px;
    gap: 64px;
    align-items: center;
  }
  .hero-kicker {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }
  .k-logo-adhd { height: 26px; width: auto; display: block; filter: brightness(0) invert(1); }
  .k-logo-talk { height: 16px; width: auto; display: block; opacity: 0.92; }
  .k-vs {
    font-family: var(--sans);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.6);
    border: 1px solid rgba(255,255,255,0.28);
    border-radius: 100px;
    padding: 3px 9px;
    line-height: 1;
  }
  .k-rest {
    font-family: var(--sans);
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
  }
  .hero h1 { color: #fff; margin-bottom: 18px; font-size: clamp(29px, 3.9vw, 46px); }
  .hero h1 .h1-line { display: block; }
  .hero h1 .em { color: #5BC8DC; white-space: nowrap; }
  .hero-doc {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.16);
    border-radius: 8px;
    padding: 24px;
  }
  .hero-doc img {
    width: 76px; height: 76px;
    border-radius: 5px;
    object-fit: cover;
    margin-bottom: 16px;
  }
  .hero-doc-name { font-family: var(--sans); font-size: 16.5px; font-weight: 700; color: #fff; }
  .hero-doc-cred {
    font-family: var(--sans); font-size: 10.5px; font-weight: 700;
    letter-spacing: 0.13em; text-transform: uppercase;
    color: #6FCBDD; margin: 4px 0 12px;
  }
  .hero-doc-line {
    font-size: 14px; line-height: 1.6; color: rgba(255,255,255,0.74);
  }
  .hero-sub {
    font-size: clamp(16px, 1.6vw, 18px);
    line-height: 1.62;
    color: rgba(255,255,255,0.78);
    max-width: 600px;
    margin-bottom: 26px;
  }
  .hero-cta-row { display: flex; align-items: center; gap: 28px; flex-wrap: wrap; margin-bottom: 14px; }
  .hero-skip {
    color: rgba(255,255,255,0.75);
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,0.35);
    padding-bottom: 2px;
    transition: color 0.15s, border-color 0.15s;
  }
  .hero-skip:hover { color: #fff; border-color: #fff; }
  .hero-meta { font-size: 13px; color: rgba(255,255,255,0.5); margin-bottom: 26px; }
  .hero-trust {
    display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
    font-size: 14px; color: rgba(255,255,255,0.82);
  }
  .hero-trust-stars { color: var(--green-tp); letter-spacing: 1px; font-size: 13px; }
  .hero-trust .tp-logo { height: 15px; width: auto; vertical-align: -2px; fill: #fff; }
  .hero-trust-sep { width: 1px; height: 13px; background: rgba(255,255,255,0.28); }

  /* hero load sequence — the page's single orchestrated motion moment */
  @keyframes rise { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: none; } }
  .hero [data-rise] { animation: rise 0.65s cubic-bezier(0.2, 0.7, 0.2, 1) both; }
  .hero [data-rise="2"] { animation-delay: 0.08s; }
  .hero [data-rise="3"] { animation-delay: 0.16s; }
  .hero [data-rise="4"] { animation-delay: 0.24s; }
  .hero [data-rise="5"] { animation-delay: 0.32s; }
  @media (prefers-reduced-motion: reduce) { .hero [data-rise] { animation: none; } }

  /* ── Featured-by band ── */
  .featured { border-bottom: 1px solid var(--line-soft); }
  .featured-inner {
    display: flex; align-items: center; gap: 40px; flex-wrap: wrap;
    padding: 22px 0;
  }
  .featured-label {
    font-family: var(--sans); font-size: 11px; font-weight: 700;
    letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-3);
    flex-shrink: 0;
  }
  .ts-press-logos { display: flex; align-items: center; gap: clamp(20px, 3vw, 36px); flex-wrap: wrap; }
  .ts-press-logos svg, .ts-press-logos img { height: 21px; width: auto; display: block; opacity: 0.85; }
  .featured-promise {
    margin-left: auto;
    font-size: 13px;
    color: var(--ink-3);
  }
  .featured-promise b { color: var(--ink-2); font-weight: 600; }
  @media (max-width: 900px) { .featured-promise { margin-left: 0; } }

  /* ── 01 · Short answer ── */
  .answer-lede {
    font-family: var(--sans);
    font-weight: 700;
    font-size: clamp(21px, 2.7vw, 29px);
    line-height: 1.4;
    color: var(--navy);
    letter-spacing: -0.02em;
    max-width: 880px;
    margin-bottom: 52px;
  }
  .answer-lede strong { font-weight: 700; color: var(--teal); }
  .answer-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-top: 1px solid var(--line);
    margin-bottom: 64px;
  }
  .answer-col { padding: 26px 40px 8px 0; }
  .answer-col + .answer-col { border-left: 1px solid var(--line); padding-left: 40px; padding-right: 0; }
  .answer-col h3 { margin-bottom: 10px; font-size: 16.5px; }
  .answer-col p { font-size: 15px; line-height: 1.7; }

  /* ── Router quiz ── */
  .router-card {
    border: 1px solid var(--line);
    background: var(--cloud);
    padding: 46px 52px 50px;
    max-width: 880px;
  }
  .router-card > h3 { font-size: 22px; letter-spacing: -0.015em; margin-bottom: 4px; color: var(--navy); }
  .router-sub { font-size: 14px; color: var(--ink-3); margin-bottom: 34px; }
  .router-q { display: none; }
  .router-q.active { display: block; }
  .router-progress {
    font-family: var(--sans); font-size: 11px; font-weight: 700;
    letter-spacing: 0.16em; color: var(--teal); margin-bottom: 10px;
  }
  .router-q-label {
    font-family: var(--sans); font-weight: 700;
    font-size: 19px; color: var(--navy); margin-bottom: 22px; letter-spacing: -0.015em;
  }
  .router-opts { display: flex; flex-direction: column; }
  .router-opt {
    text-align: left;
    background: var(--paper);
    border: 1px solid var(--line);
    margin-top: -1px;
    color: var(--ink);
    font-family: var(--text);
    font-size: 15.5px;
    padding: 17px 20px;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 14px;
    transition: border-color 0.15s, background 0.15s;
  }
  .router-opt::after { content: '\2192'; color: var(--teal); opacity: 0; transition: opacity 0.15s, transform 0.15s; transform: translateX(-4px); }
  .router-opt:hover { border-color: var(--navy); background: #fff; position: relative; z-index: 1; }
  .router-opt:hover::after { opacity: 1; transform: none; }
  .router-result { display: none; }
  .router-result.active { display: block; }
  .router-result-card {
    background: var(--paper);
    border: 1px solid var(--line);
    border-top: 3px solid var(--teal);
    padding: 30px 34px;
  }
  .router-result-card h4 {
    font-family: var(--sans); font-weight: 700;
    font-size: 19px; color: var(--navy); margin-bottom: 12px; letter-spacing: -0.015em;
  }
  .router-result-card p { font-size: 15px; line-height: 1.7; margin-bottom: 22px; }
  .router-restart {
    background: none; border: none;
    color: var(--ink-3); font-size: 13px;
    margin-top: 16px; cursor: pointer;
    text-decoration: underline;
    font-family: var(--text);
  }

  /* ── 02 · Comparison table ── */
  .swipe-hint { display: none; font-size: 12px; color: var(--ink-3); margin-bottom: 10px; font-family: var(--sans); font-weight: 600; }
  .comp-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .comp-table {
    width: 100%;
    min-width: 680px;
    border-collapse: collapse;
  }
  .comp-table th { text-align: left; vertical-align: bottom; padding: 0 22px 14px 0; }
  .comp-table th.col-adhd { border-bottom: 3px solid var(--navy); padding-left: 22px; }
  .comp-table th.col-talk { border-bottom: 1px solid var(--line); padding-left: 22px; }
  .comp-table th.col-label { border-bottom: 1px solid var(--line); width: 19%; }
  .col-name { font-family: var(--sans); font-size: 17px; font-weight: 800; letter-spacing: -0.015em; color: var(--navy); }
  .col-talk .col-name { color: var(--ink-2); font-weight: 700; }
  .col-sub { display: block; font-size: 12px; color: var(--ink-3); margin-top: 3px; font-weight: 400; }
  .col-sub .stars { color: var(--green-tp); letter-spacing: 0.5px; }
  .comp-table td {
    vertical-align: top;
    padding: 20px 22px 20px 0;
    border-bottom: 1px solid var(--line-soft);
    font-size: 14.5px;
    line-height: 1.6;
  }
  .comp-table td.row-label {
    font-family: var(--sans);
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-3);
    padding-top: 24px;
    width: 19%;
  }
  .comp-table td.cell-adhd { background: rgba(239,247,250,0.55); padding-left: 22px; color: var(--ink); width: 40.5%; }
  .comp-table td.cell-talk { padding-left: 22px; color: var(--ink-2); width: 40.5%; }
  .win-tag {
    display: block;
    font-family: var(--sans);
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 5px;
  }
  .cell-lead { font-weight: 600; color: var(--navy); }
  .cell-talk .cell-lead { color: var(--ink); }
  .cell-note { display: block; font-size: 12.5px; color: var(--ink-3); margin-top: 4px; }
  .cell-na { color: var(--ink-3); }
  .table-foot {
    font-size: 12.5px;
    color: var(--ink-3);
    max-width: 720px;
    margin-top: 18px;
    line-height: 1.6;
  }

  /* ── 03 · Specialist ── */
  .spec-grid { display: grid; grid-template-columns: 7fr 5fr; gap: 72px; align-items: start; }
  .spec-copy p { font-size: 16.5px; margin-bottom: 20px; }
  .pull-quote {
    font-family: var(--sans);
    font-weight: 700;
    font-size: clamp(21px, 2.4vw, 27px);
    line-height: 1.38;
    color: var(--navy);
    letter-spacing: -0.02em;
    margin: 34px 0 10px;
  }
  .pull-attr { font-size: 12.5px; color: var(--ink-3); letter-spacing: 0.06em; text-transform: uppercase; font-family: var(--sans); font-weight: 600; margin-bottom: 36px; }
  .stat-row { display: flex; flex-wrap: wrap; border-top: 1px solid var(--line); }
  .stat { padding: 22px 40px 6px 0; }
  .stat + .stat { border-left: 1px solid var(--line); padding-left: 40px; }
  .stat-v { font-family: var(--sans); font-size: clamp(34px, 3.4vw, 46px); font-weight: 800; letter-spacing: -0.03em; color: var(--navy); line-height: 1; }
  .stat-v .u { font-family: var(--sans); font-weight: 600; font-size: 0.42em; color: var(--ink-3); letter-spacing: 0; }
  .stat-l { font-size: 12.5px; color: var(--ink-3); margin-top: 8px; }

  .clinicians { border-top: 1px solid var(--line); }
  .clinician { display: flex; gap: 22px; padding: 26px 0; border-bottom: 1px solid var(--line); align-items: flex-start; }
  .clinician img { width: 92px; height: 92px; object-fit: cover; border-radius: 3px; flex-shrink: 0; filter: saturate(0.92); }
  .clinician h3 { font-size: 16.5px; margin-bottom: 2px; }
  .clinician .cred {
    font-family: var(--sans); font-size: 11px; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase; color: var(--teal);
    margin-bottom: 8px;
  }
  .clinician p { font-size: 13.5px; line-height: 1.62; color: var(--ink-2); }
  .clinicians-foot {
    font-size: 13px; color: var(--ink-3); padding-top: 16px; line-height: 1.6;
  }

  /* ── 04 · Honest ledger ── */
  .honest-grid { display: grid; grid-template-columns: 5fr 7fr; gap: 72px; align-items: start; }
  .honest-left h2 { margin-bottom: 18px; }
  .honest-left p { font-size: 16.5px; max-width: 420px; }
  .honest-list { border-top: 1px solid var(--line); counter-reset: hon; }
  .honest-item { display: flex; gap: 28px; padding: 30px 0; border-bottom: 1px solid var(--line); }
  .honest-item::before {
    counter-increment: hon;
    content: "0" counter(hon);
    font-family: var(--sans);
    font-weight: 700;
    font-size: 14px;
    color: var(--teal);
    flex-shrink: 0;
    line-height: 1.9;
    letter-spacing: 0.04em;
  }
  .honest-item h3 { font-size: 17px; margin-bottom: 8px; }
  .honest-item p { font-size: 14.5px; line-height: 1.68; }
  .honest-note {
    margin-top: 36px;
    padding: 24px 0 0;
    border-top: 3px solid var(--navy);
    font-size: 14.5px;
    line-height: 1.7;
    color: var(--ink-2);
    max-width: 560px;
  }
  .honest-note b { color: var(--navy); }

  /* ── 05 · Reviews ── */
  .sec--reviews { background: var(--cloud); margin-top: 88px; padding-bottom: 88px; }
  .sec--reviews .sec-head { border-top-color: rgba(3,39,92,0.2); }
  .reviews-grid { display: grid; grid-template-columns: 7fr 5fr; gap: 64px; align-items: start; }
  .review-lead blockquote {
    font-family: var(--sans);
    font-weight: 600;
    font-size: clamp(19px, 2.3vw, 25px);
    line-height: 1.5;
    color: var(--navy);
    letter-spacing: -0.015em;
    margin-bottom: 22px;
  }
  .review-side blockquote {
    font-size: 15px;
    line-height: 1.7;
    color: var(--ink-2);
    margin-bottom: 16px;
  }
  .review-item { padding: 28px 0; border-top: 1px solid rgba(3,39,92,0.16); }
  .review-item:first-child { border-top: none; padding-top: 6px; }
  .review-attr {
    display: flex; align-items: center; gap: 10px;
    font-family: var(--sans); font-size: 11px; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-3);
  }
  .review-attr .stars { color: var(--green-tp); font-size: 12px; letter-spacing: 1px; }
  .tp-summary {
    display: flex; align-items: center; gap: 14px; flex-wrap: wrap;
    border-top: 1px solid rgba(3,39,92,0.16);
    margin-top: 48px; padding-top: 26px;
    font-size: 14.5px; color: var(--ink-2);
  }
  .tp-summary .tp-logo { height: 17px; width: auto; vertical-align: -3px; fill: var(--ink); }
  .tp-summary strong { font-family: var(--sans); color: var(--navy); }

  /* ── 06 · Pricing ledgers ── */
  .pricing-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; }
  .ledger-tag {
    font-family: var(--sans); font-size: 11px; font-weight: 700;
    letter-spacing: 0.15em; text-transform: uppercase;
    margin-bottom: 10px;
  }
  .ledger--adhd .ledger-tag { color: var(--teal); }
  .ledger--talk .ledger-tag { color: var(--ink-3); }
  .ledger h3 { font-size: 21px; letter-spacing: -0.015em; margin-bottom: 22px; }
  .ledger--adhd .rows { border-top: 3px solid var(--navy); }
  .ledger--talk .rows { border-top: 1px solid var(--line); }
  .ledger-row {
    display: flex; justify-content: space-between; align-items: baseline; gap: 20px;
    padding: 15px 0;
    border-bottom: 1px solid var(--line-soft);
    font-size: 14.5px;
  }
  .ledger-row .item { color: var(--ink-2); line-height: 1.5; }
  .ledger-row .item em { font-style: normal; font-size: 12.5px; color: var(--ink-3); }
  .ledger-row .val {
    font-family: var(--sans); font-weight: 700; font-size: 16px;
    color: var(--navy); white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }
  .ledger--talk .val { color: var(--ink-2); font-weight: 600; }
  .ledger-foot {
    font-size: 13px; color: var(--ink-3);
    padding-top: 16px; line-height: 1.65;
  }

  /* ── 07 · Steps ── */
  .steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 56px; }
  .step { border-top: 1px solid var(--line); padding-top: 20px; }
  .step-n {
    font-family: var(--sans); font-weight: 800;
    font-size: 24px; color: var(--teal); display: block; margin-bottom: 14px;
    letter-spacing: -0.02em;
  }
  .step h3 { font-size: 17px; margin-bottom: 10px; }
  .step p { font-size: 14.5px; line-height: 1.68; }
  .step-tag {
    display: block; margin-top: 14px;
    font-family: var(--sans); font-size: 11px; font-weight: 700;
    letter-spacing: 0.13em; text-transform: uppercase; color: var(--ink-3);
  }

  /* ── 08 · Who ── */
  .who-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; }
  .who-col-h {
    font-family: var(--sans); font-size: 16.5px; font-weight: 800;
    letter-spacing: -0.01em; color: var(--navy);
    padding-bottom: 16px;
  }
  .who-col--adhd .who-list { border-top: 3px solid var(--navy); }
  .who-col--talk .who-list { border-top: 1px solid var(--line); }
  .who-list { list-style: none; }
  .who-list li {
    display: flex; gap: 14px; align-items: flex-start;
    padding: 15px 0;
    border-bottom: 1px solid var(--line-soft);
    font-size: 14.5px; line-height: 1.6; color: var(--ink-2);
  }
  .who-list li::before { content: '\2192'; color: var(--teal); flex-shrink: 0; font-size: 14px; line-height: 1.6; }
  .who-col--talk .who-list li::before { color: var(--ink-3); }
  .who-foot {
    font-size: 13px; color: var(--ink-3); padding-top: 16px; line-height: 1.65;
  }

  /* ── CTA band ── */
  .cta-band { background: var(--navy); margin-top: 96px; }
  .cta-grid {
    display: grid; grid-template-columns: 7fr 5fr; gap: 72px;
    padding: 84px 0 88px; align-items: center;
  }
  .cta-grid h2 { color: #fff; margin-bottom: 18px; max-width: 520px; }
  .cta-grid h2 .em { color: #5BC8DC; }
  .cta-sub { font-size: 17px; color: rgba(255,255,255,0.72); max-width: 480px; }
  .cta-right .btn { margin-bottom: 26px; }
  .btn-lg { font-size: 17px; padding: 18px 34px; }
  @media (max-width: 480px) { .btn-lg { font-size: 15px; padding: 14px 22px; } }
  .cta-spec { list-style: none; }
  .cta-spec li {
    display: flex; justify-content: space-between; gap: 20px;
    border-top: 1px solid rgba(255,255,255,0.16);
    padding: 12px 2px;
    font-size: 13.5px; color: rgba(255,255,255,0.62);
  }
  .cta-spec li b { color: rgba(255,255,255,0.92); font-weight: 600; }

  /* ── 09 · FAQ ── */
  .faq-wrap { max-width: 800px; }
  .faq-list { border-top: 1px solid var(--line); margin-top: 8px; }
  .faq-item { border-bottom: 1px solid var(--line); }
  .faq-item__question {
    width: 100%;
    background: none; border: none;
    text-align: left;
    padding: 21px 2px;
    font-family: var(--sans);
    font-size: 16.5px; font-weight: 700; letter-spacing: -0.01em;
    color: var(--navy);
    cursor: pointer;
    display: flex; justify-content: space-between; align-items: center; gap: 18px;
  }
  .faq-item__question:hover { color: var(--teal-deep); }
  .faq-mark {
    font-family: var(--text); font-weight: 400;
    font-size: 22px; color: var(--teal); flex-shrink: 0;
    transition: transform 0.25s ease;
    line-height: 1;
  }
  .faq-item.open .faq-mark { transform: rotate(45deg); }
  .faq-item__answer { max-height: 0; overflow: hidden; transition: max-height 0.32s ease; }
  .faq-item.open .faq-item__answer { max-height: 520px; }
  .faq-item__answer-inner { padding: 0 40px 24px 2px; font-size: 14.5px; line-height: 1.72; color: var(--ink-2); }
  .faq-tail { margin-top: 52px; }
  .faq-tail p { font-size: 14px; color: var(--ink-3); margin-bottom: 22px; }

  /* ── Footer ── */
  .lp-footer { background: var(--navy-deep); padding: 40px 28px 44px; color: rgba(255,255,255,0.6); margin-top: 96px; }
  .lp-footer-inner { max-width: 1140px; margin: 0 auto; display: flex; align-items: flex-start; justify-content: space-between; gap: 32px; flex-wrap: wrap; }
  .lp-footer-copy { font-size: 12px; line-height: 1.65; max-width: 640px; color: rgba(255,255,255,0.55); }
  .lp-footer-copy a { color: rgba(255,255,255,0.78); }
  .lp-footer-links { display: flex; gap: 24px; flex-wrap: wrap; }
  .lp-footer-links a { font-size: 13px; color: rgba(255,255,255,0.78); font-weight: 500; text-decoration: none; border-bottom: 1px solid transparent; }
  .lp-footer-links a:hover { border-color: rgba(255,255,255,0.5); }

  /* ── Sticky mobile CTA ── */
  .sticky-cta {
    display: none;
    position: fixed;
    bottom: 0; left: 0; right: 0;
    background: var(--navy);
    padding: 12px 18px;
    padding-bottom: calc(12px + env(safe-area-inset-bottom));
    z-index: 100;
    box-shadow: 0 -6px 24px rgba(2,26,64,0.35);
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    transform: translateY(110%);
    transition: transform 0.3s ease;
  }
  .sticky-cta.active { transform: translateY(0); }
  .sticky-cta p { color: rgba(255,255,255,0.7); font-size: 12px; line-height: 1.35; }
  .sticky-cta p strong { color: #fff; font-size: 13px; }
  .sticky-cta .btn { font-size: 14.5px; padding: 12px 20px; flex-shrink: 0; }

  /* ── Responsive ── */
  @media (max-width: 980px) {
    .hero-main { grid-template-columns: 1fr; gap: 36px; }
    .hero-doc { display: flex; gap: 18px; align-items: flex-start; padding: 18px 20px; max-width: 520px; }
    .hero-doc img { width: 62px; height: 62px; margin-bottom: 0; flex-shrink: 0; }
    .spec-grid, .honest-grid, .reviews-grid { grid-template-columns: 1fr; gap: 48px; }
    .pricing-grid, .who-grid { grid-template-columns: 1fr; gap: 56px; }
    .cta-grid { grid-template-columns: 1fr; gap: 44px; padding: 64px 0 68px; }
    .steps { grid-template-columns: 1fr; gap: 36px; }
  }
  @media (max-width: 700px) {
    .sec { padding-top: 64px; }
    .hero-main { padding: 28px 0 40px; }
    .hero-sub { margin-bottom: 22px; }
    .hero-meta { margin-bottom: 24px; }
    .sec-head { margin-bottom: 30px; flex-wrap: wrap; }
    .sec-aside { display: none; }
    .sec-intro { margin-bottom: 34px; }
    .hero-main { padding-top: 52px; }
    .hero-spec span { padding: 14px 0 16px; margin-right: 22px; }
    .hero-spec span:not(:last-child)::after { right: -11px; }
    .answer-cols { grid-template-columns: 1fr; }
    .answer-col { padding-right: 0; }
    .answer-col + .answer-col { border-left: none; border-top: 1px solid var(--line); padding-left: 0; margin-top: 8px; }
    .router-card { padding: 32px 26px 38px; }
    .swipe-hint { display: block; }
    .stat { padding-right: 20px; }
    .stat + .stat { padding-left: 20px; }
    .stat:last-child { border-left: none; padding-left: 0; }
    .honest-item { gap: 18px; }
    .sec--reviews { margin-top: 64px; padding-bottom: 64px; }
    .sticky-cta { display: flex; }
    body { padding-bottom: 76px; }
    .lp-footer { margin-top: 64px; }
    .cta-band { margin-top: 64px; }
  }
  @media (max-width: 480px) {
    .wrap { padding: 0 20px; }
    .site-header-inner { padding: 0 20px; height: 58px; }
    .site-header-logo img { width: 138px; }
    .site-header .btn { font-size: 13px; padding: 10px 14px; }
    .btn { font-size: 15px; padding: 14px 22px; }
    .hero-cta-row { gap: 18px; }
    .router-card { padding: 26px 18px 32px; }
    .sticky-cta .btn { font-size: 13.5px; padding: 11px 16px; }
  }
</style>
