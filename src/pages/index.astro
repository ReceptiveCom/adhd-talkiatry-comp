  <a href="https://www.adhdadvisor.org/initial-assessment" class="btn">
    Get started <span class="a" aria-hidden="true">&#8594;</span>
  </a>
</div>

<script is:inline>
(function() {
  // ── FAQ accordion ──
  document.querySelectorAll('.faq-item__question').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var item = btn.closest('.faq-item');
      var wasOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(function(i) { i.classList.remove('open'); });
      if (!wasOpen) item.classList.add('open');
      btn.setAttribute('aria-expanded', String(item.classList.contains('open')));
    });
  });

  // ── Router quiz ──
  var answers = {};
  var routerCard = document.getElementById('routerCard');
  if (routerCard) {
    routerCard.querySelectorAll('.router-opt').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var q = btn.closest('.router-q');
        var qNum = parseInt(q.getAttribute('data-q'), 10);
        answers[qNum] = btn.getAttribute('data-a');
        q.classList.remove('active');
        var next = routerCard.querySelector('.router-q[data-q="' + (qNum + 1) + '"]');
        if (next) {
          next.classList.add('active');
        } else {
          showResult();
        }
      });
    });
  }

  function showResult() {
    var title = document.getElementById('resultTitle');
    var body = document.getElementById('resultBody');
    var result = document.getElementById('routerResult');
    var ins = answers[1], goal = answers[2], when = answers[3];

    if (ins === 'ins-yes') {
      title.textContent = 'You can still put that insurance to work here.';
      body.textContent = 'ADHD Advisor uses flat pricing instead of in-network billing — $199 total, known before you book' + (when === 'when-now' ? ', with appointments often available same-day' : '') + '. Your HSA or FSA can cover it, and after your appointment you can submit the superbill to your insurer for possible out-of-network reimbursement. What insurance can’t buy is the focus: a 45-minute evaluation with a clinician who works on ADHD specifically.';
    } else if (goal === 'goal-ongoing') {
      title.textContent = 'ADHD Advisor fits — with one quick step.';
      body.textContent = 'Without in-network insurance, Talkiatry isn’t available (they don’t offer self-pay). ADHD Advisor works with already-diagnosed adults for ongoing medication management, therapy, and coaching at $130/month. Email support@adhdadvisor.org first so they can confirm the right pathway for your situation.';
    } else if (goal === 'goal-dx') {
      title.textContent = 'ADHD Advisor is built for exactly this.';
      body.textContent = 'A $149 evaluation-only appointment with a licensed mental health professional — flat price, no insurance involved' + (when === 'when-now' ? ', often bookable same-day' : '') + '. You get clarity first, and you can add treatment later if your clinician determines it’s appropriate. Money-back guarantee either way.';
    } else {
      title.textContent = 'ADHD Advisor is built for exactly this.';
      body.textContent = 'Since Talkiatry only sees patients with insurance they accept, your path there is closed — but you’re not stuck. A 45-minute evaluation with a doctor or NP is $199 total, price known upfront' + (when === 'when-now' ? ', with appointments often available today or tomorrow' : '') + '. If your clinician determines treatment is appropriate, you can continue care from $130/month — all without insurance ever being involved.';
    }
    result.classList.add('active');
  }

  var restart = document.getElementById('routerRestart');
  if (restart) {
    restart.addEventListener('click', function() {
      answers = {};
      document.getElementById('routerResult').classList.remove('active');
      routerCard.querySelectorAll('.router-q').forEach(function(q) { q.classList.remove('active'); });
      routerCard.querySelector('.router-q[data-q="1"]').classList.add('active');
    });
  }

  // ── Sticky CTA: show only after hero CTA scrolls out, hide at CTA band + footer ──
  var stickyCta = document.getElementById('stickyCta');
  var heroCta = document.querySelector('.hero .btn');
  if (stickyCta && heroCta) {
    var suppressZones = Array.prototype.slice.call(document.querySelectorAll('.cta-band, .lp-footer'));
    var updateSticky = function() {
      var heroOut = heroCta.getBoundingClientRect().bottom < 0;
      var vh = window.innerHeight;
      var suppress = suppressZones.some(function(z) {
        var r = z.getBoundingClientRect();
        return r.top < vh && r.bottom > 0;
      });
      stickyCta.classList.toggle('active', heroOut && !suppress);
    };
    window.addEventListener('scroll', updateSticky, { passive: true });
    window.addEventListener('resize', updateSticky);
    updateSticky();
  }

  // ── UTM passthrough: append page query params to all CTA links ──
  var params = window.location.search;
  if (params) {
    document.querySelectorAll('a[href*="adhdadvisor.org"]').forEach(function(a) {
      var href = a.getAttribute('href');
      if (href && href.indexOf('mailto:') !== 0) {
        a.setAttribute('href', href + (href.indexOf('?') !== -1 ? '&' : '?') + params.substring(1));
      }
    });
  }
})();
</script>

